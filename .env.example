# Minecraft Server RCON Configuration
# Copy this file to .env and fill in your actual values

# Your Minecraft server hostname or IP address
MC_SERVER_HOST=ubuntu-desktop

# RCON port (default is 25575 unless you changed it in server.properties)
MC_RCON_PORT=25575

# RCON password (set in your server.properties file)
MC_RCON_PASSWORD=your_rcon_password_here

## Database path (default: data/minecraft_dashboard.db)
# For Kubernetes PVC, use: /data/minecraft_dashboard.db
DB_PATH=data/minecraft_dashboard.db

# SSH Configuration for Remote Metrics Collection
# The dashboard uses SSH to collect performance metrics from the Minecraft server host

# SSH hostname or IP address (can be same as MC_SERVER_HOST)
SSH_HOST=192.168.1.206

# SSH port (default is 22)
SSH_PORT=22

# SSH username
SSH_USER=ubuntu

# Path to SSH private key (supports ~ expansion)
# For Kubernetes, mount the key as a secret and use: /secrets/ssh/mc_dashboard_key
SSH_KEY_PATH=~/.ssh/mc_dashboard_key

# Minecraft server directory on the remote host (for disk usage metrics)
# Update this path if you migrate to a different drive/mount point
MC_SERVER_DIR=/home/ubuntu/minecraft
